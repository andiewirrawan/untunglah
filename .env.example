# Supabase project URL, contoh: https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon public key dari Project Settings > API
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service_role key dari Project Settings > API.
# Jangan pernah dibagikan ke frontend/publik.
SUPABASE_SERVICE_ROLE_KEY=

# Rahasia bebas untuk tanda tangan cookie session.
# Isi dengan teks panjang acak saat production.
SESSION_SECRET=
